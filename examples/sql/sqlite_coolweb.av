pckg main;

import std.coolweb;
import std.sql;
import std.sql.sqlite;

var app | coolweb.App = coolweb.newApp();
var db | sql.DB = sql.open("sqlite://:memory:");

fun initSchema() | bool {
    return true;
}

var _schemaReady | bool = initSchema();

@app.get("/users")
async fun listUsers(ctx | coolweb.Context) | coolweb.Response {
    var rows | sql.Rows = await db.query("SELECT id, name, email FROM users", []);
    var users | list<any> = [];

    while (rows.next()) {
        var uid | int = rows.getInt("id");
        var uname | string = rows.getString("name");
        var uemail | string = rows.getString("email");
        users = users.append({
            "id": uid,
            "name": uname,
            "email": uemail
        });
    }
    rows.close();

    return ctx.json(users);
}

@app.get("/users/:id")
async fun getUser(ctx | coolweb.Context) | coolweb.Response {
    var id | string = ctx.params["id"];
    var row | sql.Row? = await db.queryRow(
        "SELECT id, name, email FROM users WHERE id = ?",
        [id]
    );

    if (row == none) {
        return ctx.json({ "error": "user not found" }, 404);
    }

    var rAny | any = row;
    var r | sql.Row = rAny;
    var rid | int = r.getInt("id");
    var rname | string = r.getString("name");
    var remail | string = r.getString("email");
    return ctx.json({
        "id": rid,
        "name": rname,
        "email": remail
    });
}

@app.post("/users")
async fun createUser(ctx | coolweb.Context) | coolweb.Response {
    var body | dict<any> = ctx.jsonBody();
    var name | string = body["name"];
    var email | string = body["email"];

    var result | sql.ExecResult = await db.exec(
        "INSERT INTO users(name, email) VALUES(?, ?)",
        [name, email]
    );

    return ctx.json({
        "created": true,
        "rowsAffected": result.rowsAffected
    }, 201);
}

@app.delete("/users/:id")
async fun deleteUser(ctx | coolweb.Context) | coolweb.Response {
    var id | string = ctx.params["id"];

    var tx | sql.Transaction = await db.begin();
    try {
        await tx.exec("DELETE FROM users WHERE id = ?", [id]);
        await tx.commit();
        return ctx.json({ "deleted": true });
    } catch (e | error) {
        await tx.rollback();
        return ctx.json({ "error": errorMessage(e) }, 500);
    }
}

async fun main() | void {
    await db.exec(
        "CREATE TABLE IF NOT EXISTS users (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL, email TEXT NOT NULL)",
        []
    );
    app.use(coolweb.loggerMiddleware);
    print("Starting SQLite-backed server on :8080...");
    await app.run(8080);
}
