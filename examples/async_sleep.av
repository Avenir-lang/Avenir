pckg main;

import std.time;

async fun delayed_greeting(name | string, delay_ms | int) | string {
    await std.time.asyncSleep(delay_ms * 1000000);
    return "Hello, " + name + "!";
}

async fun main() | void {
    var greeting | string = await delayed_greeting("World", 50);
    print(greeting);
}
