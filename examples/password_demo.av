pckg main;

import std.crypto.password as password;

fun main() | void {
    var plain | string = "pa$$w0rd";
    var hashed | string = password.hash(plain);

    print("hash: " + hashed);

    var ok | bool = password.verify("pa$$w0rd", hashed);
    var bad | bool = password.verify("123456", hashed);

    print("verify correct: ${ok}");
    print("verify wrong: ${bad}");
}
