pckg main;

fun doubler(f | fun(int, int) | int) | fun(int, int) | int {
    return fun(a | int, b | int) | int {
        return f(a, b) * 2;
    };
}

@doubler
fun add(a | int, b | int) | int {
    return a + b;
}

fun main() | void {
    var result | int = add(3, 4);
    print("add(3, 4) with @doubler = ${result}");
}
