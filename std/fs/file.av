pckg std.fs;

// Satisfies file-to-struct mapping for file.av.
struct file {}

pub struct File {
    handle | any
}

pub fun (f | File).read(n | int) | bytes {
    return __builtin_fs_read(f.handle, n);
}

pub fun (f | File).readAll() | bytes {
    var buf | bytes = fromString("");
    while (true) {
        var chunk | bytes = f.read(1024);
        if (len(chunk) == 0) {
            break;
        }
        buf = buf.concat(chunk);
    }
    return buf;
}

pub fun (f | File).readString() | string {
    return f.readAll().toString();
}

pub fun (f | File).write(data | bytes) | int {
    return __builtin_fs_write(f.handle, data);
}

pub fun (f | File).writeString(data | string) | int {
    return f.write(fromString(data));
}

pub fun (f | File).close() | void {
    __builtin_fs_close(f.handle);
}

pub async fun (f | File).asyncRead(n | int) | bytes {
    return await __builtin_async_fs_read(f.handle, n);
}

pub async fun (f | File).asyncReadAll() | bytes {
    var buf | bytes = fromString("");
    while (true) {
        var chunk | bytes = await f.asyncRead(1024);
        if (len(chunk) == 0) {
            break;
        }
        buf = buf.concat(chunk);
    }
    return buf;
}

pub async fun (f | File).asyncReadString() | string {
    var data | bytes = await f.asyncReadAll();
    return data.toString();
}

pub async fun (f | File).asyncWrite(data | bytes) | int {
    return await __builtin_async_fs_write(f.handle, data);
}

pub async fun (f | File).asyncWriteString(data | string) | int {
    return await f.asyncWrite(fromString(data));
}

pub async fun (f | File).asyncClose() | void {
    await __builtin_async_fs_close(f.handle);
}
